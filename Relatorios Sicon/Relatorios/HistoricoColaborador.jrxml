	<dataset name="HistoricoDataset" uuid="91e9c51f-71c7-4fd7-94cf-f60d33f1028d">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Sicon (Development)"/>
		<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w1" value="586"/>
		<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w2" value="401"/>
		<parameter name="TABLE_ID_COLABORADOR" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</parameter>
		<query language="sql"><![CDATA[select conc_nome, conc_data_realizacao, func_nome, fconc_carga_horaria, inst_nome, muni_nome, uf_sigla
from inscricao
    join mapa on insc_mapa_id = mapa_id_pk
    join funcao_concurso on fconc_id_pk = mapa_fconc_id
    join funcao on func_id_pk = fconc_func_id
    join concurso on conc_id_pk = fconc_conc_id
    join instituicao on inst_id_pk = mapa_inst_id
    join municipio on muni_id_pk = inst_municipio_id
    join uf on uf_id_pk = inst_uf_id
where insc_colab_id = $P{TABLE_ID_COLABORADOR}
	and insc_ativa
order by conc_data_realizacao desc]]></query>
		<field name="conc_nome" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="conc_nome"/>
			<property name="com.jaspersoft.studio.field.label" value="conc_nome"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="concurso"/>
		</field>
		<field name="conc_data_realizacao" class="java.time.LocalDate">

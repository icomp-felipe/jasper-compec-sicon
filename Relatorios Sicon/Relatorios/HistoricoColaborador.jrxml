				<expression><![CDATA["Declaramos, para os devidos fins, que o(a) colaborador(a) <b>" + $F{colab_nome} + "</b>, inscrito(a) no CPF nº <b>" + $F{colab_cpf} + "</b>, prestou serviços à Comissão Permanente de Concursos - COMPEC/UFAM, atuando na organização, fiscalização, execução e/ou apoio às atividades relacionadas aos concursos públicos e processos seletivos promovidos por esta Comissão, conforme as funções desempenhadas em cada certame listado na tabela abaixo:"]]></expression>
				<property name="com.jaspersoft.studio.unit.y" value="px"/>
				<property name="com.jaspersoft.studio.unit.width" value="px"/>
